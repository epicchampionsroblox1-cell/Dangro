# Server
PORT=3001

# Database (PostgreSQL)
# For local dev: postgresql://postgres:postgres@localhost:5432/dangro
# For Render: set DATABASE_URL in the Render dashboard to your Render PostgreSQL
# Internal Database URL. The app automatically injects ?sslmode=require if missing,
# so you DO NOT need to modify the auto-generated URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dangro

# Comma-separated list of allowed CORS origins (no spaces)
# For Render: include your GitHub Pages URL
CORS_ORIGIN=http://localhost:5173,https://your-github-username.github.io

# JWT secrets - CHANGE THESE IN PRODUCTION
JWT_SECRET=change-this-to-a-random-secret
JWT_REFRESH_SECRET=change-this-to-another-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File uploads
# For Render: use /data/uploads with a Persistent Disk
# For local dev: ./uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Environment
NODE_ENV=development
