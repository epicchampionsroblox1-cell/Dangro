{
  "name": "dangro-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "postinstall": "node -e \"const fs=require('fs');const u=process.env.UPLOAD_DIR||'./uploads';fs.mkdirSync(u,{recursive:true});console.log('Upload directory ensured');\" && npx prisma generate",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate deploy",
    "prisma:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "socket.io": "^4.8.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  }
}
