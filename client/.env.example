# Production API URL - replace with your deployed backend URL
VITE_API_URL=https://dangro.onrender.com

# WebSocket URL (optional — derived from VITE_API_URL if not set)
VITE_WS_URL=wss://dangro.onrender.com

# In development, Vite proxies /api to localhost:3001 automatically
# so no VITE_API_URL is needed for local development.
